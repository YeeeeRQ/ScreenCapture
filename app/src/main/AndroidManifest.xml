<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Capture">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Capture.Transparent"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:taskAffinity="com.example.capture.main">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".PermissionActivity"
            android:exported="false"
            android:theme="@style/Theme.Permission"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:noHistory="true"
            android:taskAffinity="com.example.capture.permission" />

        <activity-alias
            android:name=".StartRecordingActivity"
            android:targetActivity=".PermissionActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.example.capture.START" />
            </intent-filter>
        </activity-alias>

        <service
            android:name=".service.ScreenRecordService"
            android:exported="true"
            android:foregroundServiceType="mediaProjection">
            <intent-filter>
                <action android:name="com.example.capture.START" />
                <action android:name="com.example.capture.STOP" />
                <action android:name="com.example.capture.SCREENSHOT" />
                <action android:name="com.example.capture.STATUS" />
            </intent-filter>
        </service>
    </application>

</manifest>
